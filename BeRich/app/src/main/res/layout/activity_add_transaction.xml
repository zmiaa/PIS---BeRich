<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <GridLayout
        android:id="@+id/gridCategories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alignmentMode="alignMargins"
        android:columnCount="3"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/textTitle"
        tools:layout_editor_absoluteX="0dp">

        <Button
            android:id="@+id/catFood"
            style="?attr/materialIconButtonStyle"
            android:text="@string/food" />

        <Button
            android:id="@+id/catTransport"
            style="?attr/materialIconButtonStyle"
            android:text="@string/transport" />

        <Button
            android:id="@+id/catShopping"
            style="?attr/materialIconButtonStyle"
            android:text="@string/shopping" />

        <Button
            android:id="@+id/catSalary"
            style="?attr/materialIconButtonStyle"
            android:text="@string/salary" />

        <Button
            android:id="@+id/catGift"
            style="?attr/materialIconButtonStyle"
            android:text="@string/gift" />

        <Button
            android:id="@+id/catBills"
            style="?attr/materialIconButtonStyle"
            android:text="@string/bills" />
    </GridLayout>

    <TextView
        android:id="@+id/txtAmountDisplay"
        android:layout_width="233dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="260dp"
        android:background="@android:drawable/edit_text"
        android:gravity="end"
        android:padding="8dp"
        android:text="@string/inic_num"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/gridCategories" />

    <GridLayout
        android:id="@+id/numericKeyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtAmountDisplay"
        app:layout_constraintVertical_bias="0.384"
        tools:layout_editor_absoluteX="0dp">

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_1" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_2" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_3" />

        <Button
            android:id="@+id/btnPlus"
            android:layout_width="102dp"
            android:layout_height="wrap_content"
            android:backgroundTint="#D1E9FF"
            android:onClick="onTypeClick"
            android:text="@string/sum" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_4" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_5" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_6" />

        <Button
            android:id="@+id/btnMinus"
            android:layout_width="103dp"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFE0B2"
            android:onClick="onTypeClick"
            android:text="@string/resta" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_7" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_8" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/num_9" />

        <Button
            style="?attr/materialButtonOutlinedStyle"
            android:layout_columnSpan="2"
            android:onClick="onNumberClick"
            android:text="@string/inic_num" />

        <Button
            android:id="@+id/btnDot"
            style="?attr/materialButtonOutlinedStyle"
            android:onClick="onNumberClick"
            android:text="@string/dot" />

    </GridLayout>

    <Button
        android:id="@+id/btnCancel"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="120dp"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#E0E0E0"
        android:onClick="onCancelClick"
        android:text="@string/cancelar"
        android:textColor="#424242"
        app:layout_constraintBottom_toTopOf="@+id/btnSave"
        app:layout_constraintEnd_toEndOf="@+id/btnSave"
        app:layout_constraintStart_toStartOf="@+id/btnSave" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="120dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:backgroundTint="#4CAF50"
        android:onClick="onSaveTransaction"
        android:text="@string/confirmar"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>